# AI-Long-Term-Memory Service Configuration
# Copy this file to .env and fill in your actual values

# ===== REQUIRED SETTINGS =====

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=ai-long-term-memory

# OpenRouter API Key (for AI chat responses and summaries)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# API Key for service authentication (generate a secure key)
API_KEY=your-secure-api-key-here

# ===== OPTIONAL SETTINGS (with defaults) =====

# Application Settings
DEBUG=false
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8182

# Security Settings
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Memory System Parameters
MAX_DEPTH=5
SIMILARITY_THRESHOLD=0.7
DECAY_FACTOR=0.99
REINFORCEMENT_FACTOR=1.1

# Embedding Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_SIZE=1000
EMBEDDING_CACHE_TTL=3600

# Performance Settings
MAX_REQUEST_SIZE=5000

# Rate Limiting
RATE_LIMIT_CONVERSATION=30/minute
RATE_LIMIT_MEMORY=60/minute

# ===== DEVELOPMENT ONLY =====
# Set to true to enable debug features and disable authentication
# DEBUG=true

# ===== PRODUCTION DEPLOYMENT =====
# For production deployment, ensure:
# 1. DEBUG=false
# 2. Strong API_KEY (at least 32 characters)
# 3. Secure MongoDB connection string
# 4. Proper ALLOWED_ORIGINS for your domain
# 5. Consider setting DOCKER_ENV=true if running in Docker

# Docker Environment (optional)
# DOCKER_ENV=true

# ===== NOTES =====
# - Never commit your .env file to version control
# - Use strong, unique passwords and API keys
# - Rotate API keys regularly
# - Monitor your MongoDB and OpenRouter usage
# - Test all endpoints after configuration changes
